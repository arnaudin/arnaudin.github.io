---
layout: sitemap
---

{% if site.sitemap %}
{% capture site_url %}{% if site.url %}{{ site.url | append: site.baseurl }}{% else %}{{ site.github.url }}{% endif %}{% endcapture %}
  {% comment %} lastmod is only emitted when a page has a real date — a
      build-time fallback would claim every page changed on every deploy,
      which teaches crawlers to ignore the signal. {% endcomment %}
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>
  {% for page in site.html_pages %}{% unless page.sitemap == false %}{% assign page_url = site.url | append: page.url %}{% assign site_base_url = site.url | append: '/' %}{% unless page_url == site_base_url %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page.date %}
      <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
    {% endif %}{% if page.priority %}
    <changefreq>monthly</changefreq>
    <priority>{{ page.priority }}</priority>{% endif %}
  </url>
  {% endunless %}{% endunless %}{% endfor %}
  {% for page in site.projects %}<url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page.date %}
      <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
    {% endif %}
    {% if page.priority %}
      <priority>{{ page.priority }}</priority>
    {% else %}
      <priority>0.69</priority>
    {% endif %}
    <changefreq>monthly</changefreq>
  </url>
  {% endfor %}
  {% for page in site.posts %}<url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    {% if page.date %}
      <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
    {% endif %}
    <priority>{{ page.priority | default: 0.5 }}</priority>
    <changefreq>monthly</changefreq>
  </url>
  {% endfor %}
</urlset>{% endif %}
